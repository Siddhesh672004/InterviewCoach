# Backend environment variables — copy to .env and fill in
# Required for any LLM call. Get a free key at https://console.groq.com
GROQ_API_KEY=

# Optional — override the Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated list of frontend origins allowed to call the API.
# In production, set this to your deployed frontend URL, e.g.:
# ALLOWED_ORIGIN=https://your-app.web.app,https://your-app.firebaseapp.com
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173

# Render injects PORT automatically. Locally, default is 8001.
PORT=8001
